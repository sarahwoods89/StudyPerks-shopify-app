<div class="studyperks-wrapper">
  <button
    id="studyperks-wallet-connect"
    class="studyperks-badge"
    type="button"
    aria-label="StudyPerks — connect your wallet to claim your student discount"
  >
    <img
      src="{{ 'StudyPerksLogo.png' | asset_url }}"
      alt="StudyPerks"
      class="studyperks-badge__logo"
      width="32"
      height="32"
    />
    <span class="studyperks-badge__tick" id="studyperks-tick" aria-hidden="true">✓</span>
  </button>

  <div class="studyperks-tooltip" id="studyperks-tooltip">
    Connect your Phantom wallet to claim your student discount
  </div>

  <button type="button" class="studyperks-switch" id="studyperks-switch">
    Switch wallet
  </button>
</div>

<script>
  (function () {
    if (localStorage.getItem('studyperks_applied') === 'true') {
      var btn = document.getElementById('studyperks-wallet-connect');
      var tip = document.getElementById('studyperks-tooltip');
      if (btn) { btn.classList.add('studyperks-badge--applied'); btn.disabled = true; }
      if (tip) tip.classList.add('studyperks-tooltip--hidden');
    }
  })();
</script>
<script src="{{ 'connect-wallet.js' | asset_url }}" defer></script>
{{ 'studyperks.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "StudyPerks Badge",
  "target": "section",
  "settings": []
}
{% endschema %}
